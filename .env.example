# ----- Topics -----
# Comma-separated list of topics. Each item is run as a separate Google News
# search. You can use search operators inside one topic: quotes for exact
# phrases, OR for alternatives, parentheses to group, and - to exclude.
#
# Optionally give each topic a clean label with "Label | query". The label is
# the heading shown in the report; the query is sent to Google News. Without a
# "|", the query text is also used as the heading.
# Example:
#   AI Security | ("AI" OR "artificial intelligence") (cybersecurity OR malware)
TOPICS=artificial intelligence, electric vehicles, stock market

# Relevance filter (optional): keep an article only if it mentions ONE of these
# terms (whole-word, case-insensitive) in its title or body. Useful to force a
# theme (e.g. require AI terms so cybersecurity results actually relate to AI).
# Leave blank to disable filtering.
REQUIRE_KEYWORDS=

# How many top news items to fetch per topic (default 10). Items filtered out by
# REQUIRE_KEYWORDS are dropped, so the final report may contain fewer.
NEWS_PER_TOPIC=10

# De-duplication: collapse near-identical stories (same event from many outlets).
# DEDUPE_THRESHOLD is how similar two headlines must be to count as duplicates
# (0.0-1.0 Jaccard word overlap). Lower = more aggressive merging. 0.5 is a good
# start; try 0.4 if you still see repeats, 0.6 if unrelated stories get merged.
DEDUPE=true
DEDUPE_THRESHOLD=0.5

# Google News locale settings (controls the SEARCH language; keep en-US for
# broad English-language coverage).
NEWS_LANG=en-US
NEWS_COUNTRY=US

# ----- Gemini (Google AI) -----
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest
# Language for the summaries and translated titles in the report.
SUMMARY_LANGUAGE=Korean

# ----- Email (Outlook / Office365) -----
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
EMAIL_ADDRESS=you@outlook.com
EMAIL_PASSWORD=your_email_password_or_app_password
# Where to send the report (defaults to EMAIL_ADDRESS if blank)
EMAIL_TO=you@outlook.com
